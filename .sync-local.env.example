# Copy to .sync-local.env (gitignored) and adjust to your machine.
# scripts/sync-to-local.sh sources this to know where to mirror the skills.
# Defaults (if this file is absent): $HOME/.claude/skills and $HOME/.agents/skills

# Claude Code skill home (user or project scope)
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"

# Codex / cross-runtime skill home
AGENTS_SKILLS_DIR="$HOME/.agents/skills"
